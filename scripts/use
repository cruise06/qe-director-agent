#!/bin/bash
set -e

if [ "$#" -ne 2 ]; then
  echo "Usage: ./scripts/use <skill> <case_name>"
  exit 1
fi

SKILL="$1"
CASE_NAME="$2"
INPUT_FILE="06_inputs/${CASE_NAME}.md"
OUTPUT_FILE="03_templates/${CASE_NAME}_result.md"

if [ ! -f "$INPUT_FILE" ]; then
  ./scripts/newcase "$SKILL" "$CASE_NAME"
  echo ""
  echo "EDIT THIS FILE FIRST:"
  echo "  $INPUT_FILE"
  exit 0
fi

./scripts/runcase "$SKILL" "$INPUT_FILE" "$OUTPUT_FILE"
